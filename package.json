{
  "private": true,
  "name": "campaignlens",
  "version": "0.0.0",
  "license": "BSD-3-Clause",
  "type": "module",
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && vite build",
    "deploy": "npm run type-check && npm run lint && npm run test && devvit upload",
    "dev": "npm run build && devvit playtest --since 1s --show-timestamps --log-runtime",
    "launch": "npm run deploy && devvit publish",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "login": "devvit login",
    "prettier": "prettier --write .",
    "test": "vitest run",
    "type-check": "tsc --build"
  },
  "engines": {
    "node": ">=22.2.0"
  },
  "dependencies": {
    "@devvit/start": "0.12.23-next-2026-05-01-20-06-15-4d8baf0a4.0",
    "@devvit/web": "0.12.23-next-2026-05-01-20-06-15-4d8baf0a4.0",
    "@hono/node-server": "^1.19.9",
    "devvit": "0.12.23-next-2026-05-01-20-06-15-4d8baf0a4.0",
    "hono": "4.11.7",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^22.19.7",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.0",
    "eslint": "9.39.2",
    "globals": "17.2.0",
    "prettier": "3.8.1",
    "tailwindcss": "^4.2.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.54.0",
    "vite": "7.3.1",
    "vitest": "^4.1.5"
  }
}
